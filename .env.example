# ============================================================
# Tesla Vision Platform - 环境变量配置
# ============================================================
# 使用方式:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 按需修改配置
#   3. 部署:  docker compose up -d
# ============================================================

# ---------- 容器镜像配置 ----------
REGISTRY=docker.io/tesla-vision
TAG=latest

# ---------- 数据存储根目录 ----------
# 所有持久化数据（MinIO、模型、Spark 等）均挂载在此目录下
DATA_ROOT=/data/tesla-vision-platform

# ---------- MinIO 对象存储 ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- 后端 API ----------
API_PORT=8000

# ---------- 前端 ----------
FRONTEND_PORT=3000

# ---------- Ollama 大模型 ----------
OLLAMA_HOST=http://ollama:11434
OLLAMA_HOST_PORT=11435
OLLAMA_MODEL=qwen2.5:7b
# 绑定 GPU（默认 GPU 2）
OLLAMA_GPU_DEVICE=2

# ---------- 推理服务 Chinese-CLIP ----------
CLIP_SERVICE=http://chinese-clip:8500
CLIP_PORT=8500
CLIP_GPU_DEVICE=0

# ---------- 推理服务 LocateAnything ----------
LAM_SERVICE=http://locate-anything:8501
LAM_PORT=8501
LAM_GPU_DEVICE=1

# ---------- Spark 集群 ----------
SPARK_MASTER_UI_PORT=8082
SPARK_MASTER_PORT=7077
SPARK_WORKER_MEMORY=16G
SPARK_WORKER_CORES=8

# ---------- LLM 对话配置 ----------
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048